APP_NAME=Local AI Agent
APP_ENV=dev
API_KEY=
HOST=127.0.0.1
PORT=8000
RATE_LIMIT_REQUESTS_PER_MINUTE=120
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_NAME=app.log
LOG_TO_FILE=true

LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=google/gemma-4-e4b

ENABLE_MEMORY=false
MEMORY_BACKEND=noop
MEMORY_FILE_PATH=data/memory/interactions.jsonl
MEMORY_RECALL_LIMIT=5
MEMORY_MAX_RECALL_LIMIT=20

SESSION_MAX_SESSIONS=200
SESSION_MAX_MESSAGES=50

TOOL_WORKSPACE_ROOT=.
TOOL_ALLOWED_COMMANDS=git,python,pytest,uv,ruff
TOOL_COMMAND_TIMEOUT_SECONDS=30
TOOL_MAX_OUTPUT_CHARS=20000
TOOL_MAX_FILE_BYTES=200000
